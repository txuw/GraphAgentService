OVERMIND_APP_NAME=OverMindAgent
OVERMIND_APP_ENV=local
OVERMIND_HOST=0.0.0.0
OVERMIND_PORT=8000
OVERMIND_RELOAD=true
OVERMIND_LOG_LEVEL=info
OVERMIND_LLM_API_KEY=
OVERMIND_LLM_BASE_URL=
OVERMIND_LLM_MODEL=gpt-4o-mini
OVERMIND_LLM_TEMPERATURE=0
OVERMIND_LLM_TIMEOUT=60
OVERMIND_LLM_MAX_TOKENS=
OVERMIND_GRAPH_DEFAULT_NAME=text-analysis
OVERMIND_GRAPH_DEBUG=false
OVERMIND_GRAPH_ENABLE_STRUCTURED_OUTPUT=true
OVERMIND_GRAPH_CHECKPOINT_MODE=memory
OVERMIND_OBSERVABILITY_LOG_PAYLOADS=false
