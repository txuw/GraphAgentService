# 只写需要覆盖 settings.yaml 的项
# 优先级：系统环境变量 > .env > settings.yaml
APP__ENV=local
APP__HOST=0.0.0.0
APP__PORT=8000
APP__RELOAD=true
APP__LOG_LEVEL=info

# LLM 配置
LLM__PROFILES__DEFAULT__API_KEY=
LLM__PROFILES__DEFAULT__BASE_URL=
LLM__PROFILES__DEFAULT__MODEL=gpt-4o-mini
LLM__PROFILES__DEFAULT__PROVIDER=openai
LLM__PROFILES__MULT_MODEL__API_KEY=
LLM__PROFILES__MULT_MODEL__BASE_URL=
LLM__PROFILES__MULT_MODEL__MODEL=qwen3.5-plus
LLM__PROFILES__MULT_MODEL__PROVIDER=openai

# Graph Checkpoint
GRAPH__CHECKPOINT_MODE=memory
GRAPH__CHECKPOINT__POSTGRES__URL=

# Tools
TOOLS__TIME__DEFAULT_CITY=shanghai

# Graph 绑定
GRAPHS__TEXT_ANALYSIS__LLM_BINDINGS__ANALYSIS=structured_output
GRAPHS__TOOL_AGENT__LLM_BINDINGS__AGENT=tool_calling

# Logto 认证
LOGTO__ENABLED=false
LOGTO__ISSUER_URI=
LOGTO__AUDIENCE=
LOGTO__JWK_SET_URI=

# MCP 服务
MCP__CONNECTIONS__SPORT__URL=

# 记忆服务（Mem0）
MEMORY__ENABLED=false
MEMORY__VECTOR_STORE__URL=
MEMORY__VECTOR_STORE__TOKEN=

# 可观测性
OBSERVABILITY__LOG_PAYLOADS=false
